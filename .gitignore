# dependencies & build
node_modules/
dist/
dist-electron/
release/
*.tsbuildinfo

# secrets & local config  — NEVER commit
.env
.env.bak*
.env.backup*
.env.local
.env.*.local
*.pem
*.key
# signing material — code-signing certs / provisioning / private keys of every format
*.p12
*.pfx
*.cer
*.crt
*.p8
*.mobileprovision
*.certSigningRequest
sam-signing/

# runtime memory (personal — keep folders, ignore contents)
vault/daily/*.md
!vault/daily/.gitkeep
vault/memory.json
vault/memory.db*
vault/authorized.json

# logs & caches (runtime + launchd .out/.err — never committed)
*.log
logs/
.cache/
coverage/
.vitest/

# os / editor
.DS_Store
._*
Thumbs.db
.idea/
.vscode/
__pycache__/
*.pyc

# Personal data — stays on YOUR machine, never shipped (each user has their own)
vault/brands.json
vault/memory.json
vault/socials.json
vault/authorized.json
vault/projects/*.md
vault/daily/*
!vault/**/.gitkeep

# bulletproof: no vault data ships
vault/**/*.json
vault/**/*.enc
vault/**/*.jsonl
vault/**/*.dpapi
vault/threshold/
vault/**/*.md
vault/**/*.jpg
vault/**/*.jpeg
vault/**/*.png
vault/**/*.webp
vault/**/*.gif
vault/**/*.mp4
vault/**/*.heic
vault/studio-gen/
vault/studio-previews/
!vault/brands.sample.json
!vault/**/.gitkeep

# proactive local data
vault/nudges.json
vault/proactive-state.json

vault/people.json

# landing is generated by the pages workflow, not committed
docs/index.html
dist-app/
!vault/mcp.sample.json
vault/photos/
vault/owner.json

# anonymous per-install gateway device id (never shared)
vault/.device-id

# generated package manifests (filled at release)
packaging/out/

# test/CI artifacts (playwright, recordings, stray root probe scripts)
test-results/
playwright-report/
*.webm
/verify-*.mjs
/capture-*.mjs
/*-shot.mjs
/*-smoke.mjs

# bench outputs (keep bench/ source, ignore generated results)
bench/results/
bench/*.out.json

# agent worktrees (transient, live inside the repo)
.claude/worktrees/

# Internal ops/research notes — kept local, never public
CLAUDE.md
docs/BOARD.md
docs/OWNERSHIP_AUDIT.md
docs/strips/
