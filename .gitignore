# dependencies & build
node_modules/
dist/
dist-electron/
release/
*.tsbuildinfo

# secrets & local config  — NEVER commit
.env
.env.local
.env.*.local
*.pem
*.key

# runtime memory (personal — keep folders, ignore contents)
vault/daily/*.md
!vault/daily/.gitkeep
vault/memory.json
vault/memory.db*
vault/authorized.json

# logs & caches
*.log
.cache/
coverage/
.vitest/

# os / editor
.DS_Store
._*
Thumbs.db
.idea/
.vscode/
__pycache__/
*.pyc

# Personal data — stays on YOUR machine, never shipped (each user has their own)
vault/brands.json
vault/memory.json
vault/socials.json
vault/authorized.json
vault/projects/*.md
vault/daily/*
!vault/**/.gitkeep

# bulletproof: no vault data ships
vault/**/*.json
vault/**/*.md
vault/**/*.jpg
vault/**/*.jpeg
vault/**/*.png
vault/**/*.webp
vault/**/*.gif
vault/**/*.mp4
vault/**/*.heic
vault/studio-gen/
vault/studio-previews/
!vault/brands.sample.json
!vault/**/.gitkeep

# proactive local data
vault/nudges.json
vault/proactive-state.json

vault/people.json

# landing is generated by the pages workflow, not committed
docs/index.html
dist-app/
!vault/mcp.sample.json
vault/photos/
vault/owner.json

# anonymous per-install gateway device id (never shared)
vault/.device-id
