{
  "name": "sam",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "description": "S.A.M. — Smart Artificial Mind. Your private, free, local-first AI assistant that actually does things.",
  "scripts": {
    "dev": "concurrently -k -n \"SERVER,HUD\" -c \"#E8673A,#C4A882\" \"npm:dev:server\" \"npm:dev:hud\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:hud": "vite",
    "dev:electron": "vite",
    "build": "NODE_OPTIONS=--max-old-space-size=8192 vite build",
    "build:mac": "NODE_OPTIONS=--max-old-space-size=8192 vite build && electron-builder --mac",
    "start": "NODE_OPTIONS=--max-old-space-size=8192 vite build && tsx server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "skill:new": "node scripts/new-skill.mjs",
    "prestart": "node scripts/selfupdate.mjs",
    "ship": "node scripts/ship.mjs",
    "landing": "node scripts/gen-landing.mjs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "playwright-core": "^1.61.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-electron": "^1.1.0",
    "vite-plugin-electron-renderer": "^1.0.0",
    "vitest": "^2.1.8",
    "ws": "^8.21.0"
  }
}
