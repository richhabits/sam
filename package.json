{
  "name": "sam",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "description": "S.A.M. — Smart Artificial Mind. Your private, free, local-first AI assistant that actually does things.",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "concurrently -k -n \"SERVER,HUD\" -c \"#E8673A,#C4A882\" \"npm:dev:server\" \"npm:dev:hud\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:hud": "vite",
    "build": "NODE_OPTIONS=--max-old-space-size=8192 vite build && npm run build:server",
    "build:server": "esbuild server/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/server.mjs",
    "build:mac": "node scripts/preflight-build.mjs && npm run build && electron-builder --mac",
    "build:win": "node scripts/preflight-build.mjs && npm run build && electron-builder --win",
    "build:linux": "node scripts/preflight-build.mjs && npm run build && electron-builder --linux",
    "build:all": "node scripts/preflight-build.mjs && npm run build && electron-builder -mwl",
    "start": "npm run build && node dist/server.mjs",
    "start:fast": "node dist/server.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm test && npm run build",
    "selftest": "tsx server/selftest.ts",
    "skill:new": "node scripts/new-skill.mjs",
    "ship": "node scripts/ship.mjs",
    "landing": "node scripts/gen-landing.mjs",
    "og": "node scripts/gen-og.mjs",
    "build:mac:signed": "node scripts/build-signed.mjs",
    "release:app": "node scripts/build-signed.mjs --upload"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.11.1",
    "bonjour-service": "^1.4.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "electron-updater": "^6.8.9",
    "express": "^4.21.2",
    "mammoth": "^1.12.0",
    "nodemailer": "^9.0.3",
    "pdf-parse": "^2.4.5",
    "playwright-core": "^1.61.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^8.0.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^8.1.3",
    "vite-plugin-electron": "^1.1.0",
    "vite-plugin-electron-renderer": "^1.0.0",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "com.hectic.sam",
    "productName": "SAM",
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "**/*",
      "!vault/**",
      "!.env",
      "!.env.*",
      "!**/*.test.*",
      "!dist-app/**",
      "!.git/**"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/playwright-core/**"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "maintainer": "HECTIC"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "richhabits",
        "repo": "sam"
      }
    ]
  }
}
