# ───────────────────────────────────────────────
#  S.A.M. · Smart Artificial Mind · environment
#  Runs FREE by default on rotating cloud free-tiers; add any
#  free key below. No key at all? It falls back to local Ollama
#  (100% offline). Keys are pooled + rotating (comma-list = …_KEYS)
#  so you never hit a rate limit.
# ───────────────────────────────────────────────

# Default tier: "free" = rotating free cloud brains (needs ≥1 free key,
# else falls back to local Ollama). Set "local" to force offline Ollama only.
DEFAULT_TIER=free

# LOCAL · Ollama (free, on your machine: `ollama serve`)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_VISION_MODEL=llava

# FREE cloud fallbacks (all optional) — pooled, rotating
GEMINI_API_KEYS=
GROQ_API_KEYS=
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEYS=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# PREMIUM (optional) — Claude / OpenAI
ANTHROPIC_API_KEYS=
CLAUDE_MODEL=claude-sonnet-5
OPENAI_API_KEYS=
OPENAI_MODEL=gpt-4o-mini

# Ports & host
PORT=8787
# The API binds to 127.0.0.1 (loopback) only. Override the host at your own risk —
# it has no auth and can run shell commands, so never expose it to a network.
# SAM_HOST=127.0.0.1

# ── P2P swarm (optional, OFF by default) ───────────────────────
# Lets other SAMs on your LAN send tasks to this one — which runs your agent loop,
# so it's opt-in AND token-gated. Set both on every machine you want to link, using
# the SAME token. Without a token, incoming peer tasks are refused.
# SAM_P2P=1
# SAM_P2P_TOKEN=
# P2P_PORT=8788

# Vault location (where memory, brands, docs live). Defaults to ./vault.
# VAULT_DIR=

# ── SAM's own email (optional) ─────────────────────────────────
# Give SAM an address so it can email your morning brief + capacity nudges and send
# mail on its own (the send_mail tool). Any SMTP works — Gmail (create an "App
# password"), IONOS, Fastmail, etc. Port 465 = implicit TLS, 587 = STARTTLS.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=sam@yourdomain.com
# SMTP_PASS=your-app-password
# SMTP_FROM=SAM <sam@yourdomain.com>
# SAM_OWNER_EMAIL=you@yourdomain.com

# PREMIUM VOICE (optional) — ElevenLabs. Paste your key and SAM speaks in this voice.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_turbo_v2_5

# ── COST NOTES (SAM is free by default) ────────────────────────
# FREE  : Ollama (local), Gemini/Groq/OpenRouter free tiers, Jina free tier.
#         Default answers use Groq (free). Photos use Gemini (free).
# PAID  : ANTHROPIC/OPENAI keys are used when you pick "Best" quality. OPENAI_API_KEY
#         also powers the optional Realtime Voice Mode and the Creative Space image
#         proxy (both paid, both opt-in). Free chat NEVER falls through to paid models.
# ELEVENLABS : bills per character. Only speaks when you turn on read-aloud
#              or use Voice Mode; each reply is capped to 800 chars.

# ── FREE MODEL PROVIDERS (rolling pools — add multiple keys as k1,k2,…) ─────
# SAM rotates across ALL of these; if one hits its limit it uses the next.
NVIDIA_API_KEYS=          # build.nvidia.com — capable 70B, generous free
GROQ_API_KEYS=            # console.groq.com/keys — fastest 70B
CEREBRAS_API_KEYS=        # cloud.cerebras.ai — blazing fast 70B
MISTRAL_API_KEYS=         # console.mistral.ai/api-keys — free tier
GITHUB_TOKEN=             # github.com/settings/tokens — GitHub Models, free
GEMINI_API_KEYS=          # aistudio.google.com/apikey — vision + small daily cap
OPENROUTER_API_KEYS=      # openrouter.ai/keys (free models need a little credit)
SAMBANOVA_API_KEYS=       # cloud.sambanova.ai — totally free 70B
TOGETHER_API_KEYS=        # together.ai — extremely fast Llama
DEEPSEEK_API_KEYS=        # platform.deepseek.com — insanely cheap
FIREWORKS_API_KEYS=       # fireworks.ai — generous free tier
XAI_API_KEYS=             # console.x.ai — free dev credits
HUGGINGFACE_API_KEYS=     # huggingface.co/settings/tokens — free serverless
HYPERBOLIC_API_KEYS=      # app.hyperbolic.xyz — free open weights
NOVITA_API_KEYS=          # novita.ai — very cheap
SILICONFLOW_API_KEYS=     # siliconflow.cn — free open weights
GLHF_API_KEYS=            # glhf.chat — free Llama
AI21_API_KEYS=            # studio.ai21.com — free Jamba trials
UPSTAGE_API_KEYS=         # console.upstage.ai — Solar mini free trial
NEBIUS_API_KEYS=          # nebius.ai — free credits
COHERE_API_KEYS=          # dashboard.cohere.com — free Command R
PERPLEXITY_API_KEYS=      # perplexity.ai — API credits
# optional model overrides:
# NVIDIA_MODEL=meta/llama-3.3-70b-instruct
# CEREBRAS_MODEL=llama-3.3-70b
# MISTRAL_MODEL=mistral-small-latest
# GITHUB_MODEL=gpt-4o-mini
