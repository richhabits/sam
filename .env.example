# ───────────────────────────────────────────────
#  S.A.M. · Smart Artificial Mind · environment
#  Runs 100% FREE & LOCAL by default (Ollama, no key).
#  Cloud keys are OPTIONAL fallbacks — pooled + rotating.
#  Give a provider multiple keys as a comma-list (…_KEYS)
#  and SAM round-robins them so you never hit a rate limit.
# ───────────────────────────────────────────────

# Default tier — local Ollama needs NO key
DEFAULT_TIER=free

# LOCAL · Ollama (free, on your machine: `ollama serve`)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# FREE cloud fallbacks (all optional) — pooled, rotating
GEMINI_API_KEYS=
GROQ_API_KEYS=
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEYS=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# PREMIUM (optional) — Claude / OpenAI
ANTHROPIC_API_KEYS=
CLAUDE_MODEL=claude-sonnet-5
OPENAI_API_KEYS=
OPENAI_MODEL=gpt-4o-mini

# Ports
PORT=8787
VOICE_URL=http://localhost:8788

# Voice sidecar (optional, 100% local)
WHISPER_MODEL=base.en
VOICE_PORT=8788

# PREMIUM VOICE (optional) — ElevenLabs. Paste your key and SAM speaks in this voice.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_turbo_v2_5

# ── COST NOTES (SAM is free by default) ────────────────────────
# FREE  : Ollama (local), Gemini/Groq/OpenRouter free tiers, Jina free tier.
#         Default answers use Groq (free). Photos use Gemini (free).
# PAID  : ANTHROPIC/OPENAI keys are ONLY used when you pick "Best" quality.
#         Free requests NEVER fall through to paid models.
# ELEVENLABS : bills per character. Only speaks when you turn on read-aloud
#              or use Voice Mode; each reply is capped to 800 chars.

# ── FREE MODEL PROVIDERS (rolling pools — add multiple keys as k1,k2,…) ─────
# SAM rotates across ALL of these; if one hits its limit it uses the next.
NVIDIA_API_KEYS=          # build.nvidia.com — capable 70B, generous free
GROQ_API_KEYS=            # console.groq.com/keys — fastest 70B
CEREBRAS_API_KEYS=        # cloud.cerebras.ai — blazing fast 70B
MISTRAL_API_KEYS=         # console.mistral.ai/api-keys — free tier
GITHUB_TOKEN=             # github.com/settings/tokens — GitHub Models, free
GEMINI_API_KEYS=          # aistudio.google.com/apikey — vision + small daily cap
OPENROUTER_API_KEYS=      # openrouter.ai/keys (free models need a little credit)
# optional model overrides:
# NVIDIA_MODEL=meta/llama-3.3-70b-instruct
# CEREBRAS_MODEL=llama-3.3-70b
# MISTRAL_MODEL=mistral-small-latest
# GITHUB_MODEL=gpt-4o-mini
